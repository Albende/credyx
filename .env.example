# --- Infrastructure ---
DATABASE_URL=postgresql+asyncpg://creditlens:creditlens@localhost:5432/creditlens
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO

# --- LLM (kie.ai / Gemini) ---
# Get a key at https://kie.ai/
KIE_AI_API_KEY=
KIE_AI_MODEL=gemini-2.0-flash

# --- Country API keys (per-adapter) ---
# UK Companies House: https://developer.company-information.service.gov.uk/get-started
UK_COMPANIES_HOUSE_API_KEY=

# Netherlands KvK: https://developers.kvk.nl/
NL_KVK_API_KEY=
NL_KVK_BASE_URL=https://api.kvk.nl/api/v2  # use test url in dev

# OpenCorporates (free tier: 500 req/month)
OPENCORPORATES_API_KEY=

# OpenSanctions (optional — free without key but rate-limited)
OPENSANCTIONS_API_KEY=

# SEC EDGAR requires descriptive User-Agent with contact info
SEC_EDGAR_USER_AGENT=CreditLens dev your-email@example.com

# Denmark CVR (virk.dk distribution): https://datacvr.virk.dk/data/cvr-hjaelp/sadan-soger-du-data-fra-cvr-permanent
DK_VIRK_USERNAME=
DK_VIRK_PASSWORD=

# Ireland CRO (Companies Registration Office CWS): https://services.cro.ie/
IE_CRO_API_USERNAME=
IE_CRO_API_PASSWORD=

# Japan NTA Corporate Number API: https://www.houjin-bangou.nta.go.jp/webapi/
JP_HOJIN_BANGO_APP_ID=

# South Korea OpenDART (FSS): https://opendart.fss.or.kr/
KR_OPENDART_API_KEY=

# Australia ABN Lookup (free GUID): https://abr.business.gov.au/Tools/WebServices
AU_ABN_LOOKUP_GUID=

# New Zealand NZBN API (Companies Office): https://api.business.govt.nz/api-portal
NZ_NZBN_API_KEY=

# --- Browser pool (Playwright) ---
# Used by adapters that need to drive JS-rendered registries (GE, ME, MX, IN...).
# Install Chromium once with: `make install-browsers`
# (equivalent to `python -m playwright install chromium`).
BROWSER_POOL_SIZE=5
BROWSER_HEADLESS=true

# --- Proxy (optional, off by default) ---
# Leave PROXY_SERVER unset to go direct. When set, all browser-pool traffic
# (and any adapter that opts in) routes through this proxy.
# PROXY_SERVER=http://proxy.example.com:22225
# PROXY_USER=
# PROXY_PASS=
# PROXY_ROTATION=per_request  # or per_session

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://127.0.0.1:3005

# FlareSolverr (Cloudflare/Akamai bot-wall bypass) — optional
# Docker: docker run -d --name creditlens-flaresolverr -p 8191:8191 ghcr.io/flaresolverr/flaresolverr:latest
FLARESOLVERR_URL=http://localhost:8191
FLARESOLVERR_TIMEOUT_MS=60000
